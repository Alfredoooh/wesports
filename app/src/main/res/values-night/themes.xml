<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.wilin" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#2E8CFF</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/splash_background_dark</item>
    </style>
    <style name="Theme.wilin.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.wilin</item>
    </style>
    <style name="Theme.wilin.NoActionBar" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#2E8CFF</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>