<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WeVpn" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/splash_background_light</item>
    </style>
    <style name="Theme.WeVpn.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background_light</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.WeVpn</item>
    </style>
    <style name="Theme.WeVpn.NoActionBar" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>